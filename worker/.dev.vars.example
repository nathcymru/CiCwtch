# Local Wrangler development secrets for CiCwtch Worker
# Copy to .dev.vars and replace with a real local-only secret.
API_BEARER_TOKEN=replace-with-a-long-random-local-dev-token
CICWTCH_GOOGLE_WEATHER_API=replace-with-your-google-weather-api-key
CICWTCH_GOOGLE_WEATHER_SECRET=replace-with-your-google-weather-secret
